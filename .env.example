# Copy this file to ".env" in the project root before running `docker compose up`.
# docker-compose.yml loads ".env" automatically.
#
# POSTGRES_PASSWORD has no default and is required — docker compose will refuse
# to start without it, so you can't accidentally run on a guessable password.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-use-a-real-secret
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

PROJECT_NAME=Inventory & Order Management System
API_V1_STR=/api/v1

FRONTEND_PORT=3000

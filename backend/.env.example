PROJECT_NAME="Inventory & Order Management System"
API_V1_STR=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Use "localhost" when running the backend directly on your machine.
# docker-compose.yml overrides this to "db" (the postgres service name) automatically.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=inventory_db

# Optional: overrides the individual POSTGRES_* values above
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/inventory_db
